            "body": { "mode": "raw", "raw": "{\n  \"name\": \"\",\n  \"page\": 1,\n  \"page_size\": 50\n}" },
            "url": { "raw": "{{baseUrl}}/issuer/groups/search", "host": ["{{baseUrl}}"], "path": ["issuer", "groups", "search"] },
            "description": "Searches Groups by name and other attributes."
          }
        }
      ]
    },
