{
  "info": {
    "name": "Accredible API",
    "description": "Issue, manage, and verify digital credentials (certificates and Open Badges) with Accredible. Base URL: https://api.accredible.com/v1 (sandbox: https://sandbox.api.accredible.com/v1). Authenticate with an API key in the Authorization header using the scheme `Token token=YOUR_API_KEY`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "apikey",
    "apikey": [
      { "key": "key", "value": "Authorization", "type": "string" },
      { "key": "value", "value": "Token token={{apiKey}}", "type": "string" },
      { "key": "in", "value": "header", "type": "string" }
    ]
  },
  "variable": [
    { "key": "baseUrl", "value": "https://api.accredible.com/v1", "type": "string" },
    { "key": "apiKey", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Credentials",
      "item": [
        {
          "name": "Create a credential",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"credential\": {\n    \"recipient\": { \"name\": \"Jane Doe\", \"email\": \"jane@example.com\" },\n    \"group_id\": 12345,\n    \"name\": \"Course Name\",\n    \"issued_on\": \"05/07/2026\"\n  }\n}" },
            "url": { "raw": "{{baseUrl}}/credentials", "host": ["{{baseUrl}}"], "path": ["credentials"] },
            "description": "Issues a new credential to a recipient against a Group."
          }
        },
        {
          "name": "Bulk create credentials",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"credentials\": []\n}" },
            "url": { "raw": "{{baseUrl}}/credentials/bulk_create", "host": ["{{baseUrl}}"], "path": ["credentials", "bulk_create"] },
            "description": "Issues many credentials in a single request."
          }
        },
        {
          "name": "View a credential",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/credentials/:id", "host": ["{{baseUrl}}"], "path": ["credentials", ":id"], "variable": [{ "key": "id", "value": "" }] },
            "description": "Retrieves a single credential by ID."
          }
        },
        {
          "name": "Update a credential",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"credential\": {}\n}" },
            "url": { "raw": "{{baseUrl}}/credentials/:id", "host": ["{{baseUrl}}"], "path": ["credentials", ":id"], "variable": [{ "key": "id", "value": "" }] },
            "description": "Updates an existing credential."
          }
        },
        {
          "name": "Delete a credential",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/credentials/:id", "host": ["{{baseUrl}}"], "path": ["credentials", ":id"], "variable": [{ "key": "id", "value": "" }] },
            "description": "Deletes a credential by ID."
          }
        },
        {
          "name": "Search for credentials",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"group_id\": 12345,\n  \"page\": 1,\n  \"page_size\": 50\n}" },
            "url": { "raw": "{{baseUrl}}/credentials/search", "host": ["{{baseUrl}}"], "path": ["credentials", "search"] },
            "description": "Searches credentials by group, recipient, and other attributes."
          }
        },
        {
          "name": "Generate PDFs for credentials",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"credential_ids\": []\n}" },
            "url": { "raw": "{{baseUrl}}/credentials/generate_pdf", "host": ["{{baseUrl}}"], "path": ["credentials", "generate_pdf"] },
            "description": "Generates certificate PDFs for a set of credentials."
          }
        },
        {
          "name": "Generate PDF for a single credential",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/credentials/generate_single_pdf/:id", "host": ["{{baseUrl}}"], "path": ["credentials", "generate_single_pdf", ":id"], "variable": [{ "key": "id", "value": "" }] },
            "description": "Generates a certificate PDF for one credential."
          }
        },
        {
          "name": "Verify blockchain credential",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/credentials/blockchain_data/:encoded_id", "host": ["{{baseUrl}}"], "path": ["credentials", "blockchain_data", ":encoded_id"], "variable": [{ "key": "encoded_id", "value": "" }] },
            "description": "Returns the blockchain verification record for an encoded credential ID."
          }
        },
        {
          "name": "View credential analytics",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/credentials/analytics/:id", "host": ["{{baseUrl}}"], "path": ["credentials", "analytics", ":id"], "variable": [{ "key": "id", "value": "" }] },
            "description": "Returns engagement analytics for a single credential."
          }
        },
        {
          "name": "Credential redirect",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/issuer/credential_redirect?id=", "host": ["{{baseUrl}}"], "path": ["issuer", "credential_redirect"], "query": [{ "key": "id", "value": "" }] },
            "description": "Resolves and redirects to a credential's public page."
          }
        }
      ]
    },
